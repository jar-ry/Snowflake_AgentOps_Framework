# Deployment configuration — controls WHERE CI/CD deploys objects.
#
# Each environment maps to a specific Snowflake database/schema.
# The repo holds ONE definition of each object (semantic_views/*.yaml, agents/*.sql).
# CI evaluates against DEV. CD deploys to PROD after passing quality gates.
#
# SECURITY: Only the CICD_DEPLOY_ROLE (granted to the CI/CD service user)
# has CREATE permissions on the prod database. Developers cannot deploy to
# prod manually — only merges to main trigger the CD pipeline.

environments:
  dev:
    database: "{{DEV_DATABASE}}"
    semantic_view_schema: "{{DEV_SV_SCHEMA}}"
    agent_schema: "{{DEV_AGENT_SCHEMA}}"
    warehouse: "{{WAREHOUSE}}"

  prod:
    database: "{{PROD_DATABASE}}"
    semantic_view_schema: "{{PROD_SV_SCHEMA}}"
    agent_schema: "{{PROD_AGENT_SCHEMA}}"
    warehouse: "{{WAREHOUSE}}"

# CI/CD service user and role (created during setup)
cicd:
  role: CICD_DEPLOY_ROLE
  github_user: github_cicd_user
  azure_user: ado_cicd_user
