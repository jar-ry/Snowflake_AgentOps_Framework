# Agent Spec YAML Template (pure spec — no SQL wrapper)
# This file is generated by the bootstrap skill from DESCRIBE AGENT → JSON → YAML.
# At deploy time, deploy.py wraps this in CREATE OR REPLACE AGENT using the FQN
# and COMMENT from config/environments.yaml.
#
# Deploy with: python setup/deploy.py --target agent --environment <env>
# Edit in: Snowsight UI → re-capture, or directly in this file on a feature branch.

models:
  orchestration: auto

orchestration:
  budget:
    seconds: 30
    tokens: 16000

instructions:
  response: |
    Present results clearly with context and business interpretation.
    Round financial figures to 2 decimal places.
  orchestration: |
    Always use the semantic view to query data.
    When the question is ambiguous, ask clarifying questions before querying.
  system: |
    You are an analytics assistant.

    CAPABILITIES:
    - Answer questions using the semantic view
    - Generate SQL queries through Cortex Analyst
    - Provide data-driven insights

    BOUNDARIES:
    - Only answer questions related to the available data
    - Do not perform data modifications
    - Politely redirect out-of-scope questions
  sample_questions:
    - question: "What was our revenue last quarter?"
    - question: "Who are the top 10 customers?"

tools:
  - tool_spec:
      type: cortex_analyst_text_to_sql
      name: your_tool_name
      description: |
        Converts natural language questions to SQL queries against
        your analytics data.

tool_resources:
  your_tool_name:
    semantic_view: DATABASE.SCHEMA.YOUR_SEMANTIC_VIEW
    execution_environment:
      type: warehouse
      warehouse: YOUR_WAREHOUSE
