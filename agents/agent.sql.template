-- Agent Template
-- Copy this file and rename to match your agent (e.g. my_agent.sql).
-- The bootstrap-from-existing skill generates this automatically from DESCRIBE AGENT.
--
-- GET_DDL does not support AGENT type, so this is reconstructed from the agent_spec JSON.

CREATE OR REPLACE AGENT DATABASE.SCHEMA.YOUR_AGENT_NAME
  COMMENT = 'Description of your agent'
  SPEC = $$
models:
  orchestration: auto

instructions:
  response: |
    Your response instructions here.
  orchestration: |
    Your orchestration instructions here.

tools:
  - tool_spec:
      type: cortex_analyst_text_to_sql
      name: your_tool_name
      description: >
        Description of what this tool does.

tool_resources:
  your_tool_name:
    execution_environment:
      type: warehouse
      warehouse: YOUR_WAREHOUSE
    semantic_view: DATABASE.SCHEMA.YOUR_SEMANTIC_VIEW
$$;
