# Semantic View YAML Template (native format)
# This file is generated by the bootstrap skill via:
#   SELECT SYSTEM$READ_YAML_FROM_SEMANTIC_VIEW('<fqn>') AS yaml;
#
# Deploy with: python setup/deploy.py --target semantic_view --environment <env>
# Edit in: Snowsight UI → re-capture, or directly in this file on a feature branch.

name: YOUR_SEMANTIC_VIEW_NAME
description: "Human-readable description of this semantic view"

tables:
  - name: CUSTOMERS
    description: "Customer master data"
    base_table:
      database: YOUR_DATABASE
      schema: YOUR_SCHEMA
      table: CUSTOMERS
    primary_key:
      columns:
        - CUSTOMER_ID
    dimensions:
      - name: CUSTOMER_SEGMENT
        synonyms:
          - segment
        description: "Business segment classification"
        expr: CUSTOMER_SEGMENT
        data_type: VARCHAR
        is_enum: true
        sample_values:
          - Consumer
          - Corporate
          - Enterprise
    time_dimensions:
      - name: CREATED_AT
        description: "Date the customer account was created"
        expr: CREATED_AT
        data_type: DATE
    facts:
      - name: LIFETIME_VALUE
        description: "Total lifetime value in USD"
        expr: LIFETIME_VALUE
        data_type: NUMBER
    metrics:
      - name: TOTAL_CUSTOMERS
        description: "Total number of unique customers"
        expr: COUNT(CUSTOMER_ID)
      - name: AVG_LIFETIME_VALUE
        description: "Average customer lifetime value in USD"
        expr: AVG(LIFETIME_VALUE)

relationships:
  - name: ORDERS_TO_CUSTOMERS
    left_table: ORDERS
    right_table: CUSTOMERS
    relationship_columns:
      - left_column: CUSTOMER_ID
        right_column: CUSTOMER_ID

metrics:
  - name: REVENUE_PER_CUSTOMER
    description: "Average revenue per customer (derived metric)"
    expr: ORDERS.TOTAL_REVENUE / CUSTOMERS.TOTAL_CUSTOMERS

verified_queries:
  - name: top_customers
    question: "Who are the top 10 customers by lifetime value?"
    verified_by: Your Name
    verified_at: 0
    use_as_onboarding_question: true
    sql: |
      SELECT CUSTOMER_SEGMENT, AVG(LIFETIME_VALUE) AS avg_ltv
      FROM YOUR_SEMANTIC_VIEW
      GROUP BY CUSTOMER_SEGMENT
      ORDER BY avg_ltv DESC
      LIMIT 10
