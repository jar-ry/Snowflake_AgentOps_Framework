# Semantic View Template
# Copy this file and rename to match your semantic view (e.g. my_analytics_view.yaml).
# The bootstrap-from-existing skill generates this automatically from GET_DDL output.
#
# To deploy changes: python semantic_views/generate_ddl.py <this_file>.yaml | snowsql

fqn: DATABASE.SCHEMA.YOUR_SEMANTIC_VIEW_NAME

tables:
  - alias: TABLE_ALIAS
    source: DATABASE.SCHEMA.SOURCE_TABLE_NAME

dimensions:
  - table: TABLE_ALIAS
    column: COLUMN_NAME
    comment: "Human-readable description of this dimension"

verified_queries:
  - question: "What is the total revenue by region?"
    verified_by: Your Name
    verified_at: 0
    sql: |
      SELECT REGION, SUM(REVENUE) AS total_revenue
      FROM DATABASE.SCHEMA.SOURCE_TABLE
      GROUP BY REGION
      ORDER BY total_revenue DESC;
